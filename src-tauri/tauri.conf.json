{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "unsigned Char",
  "version": "0.0.10",
  "identifier": "com.char.unsigned.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "unsigned Char",
        "width": 420,
        "minWidth": 420,
        "maxWidth": 420,
        "height": 640,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "copyright": "Copyright (c) 2026 John Jeong",
    "macOS": {
      "minimumSystemVersion": "15.0",
      "entitlements": "./Entitlements.plist"
    },
    "externalBin": [
      "binaries/uchar"
    ],
    "resources": [
      "resources/models",
      "resources/scripts"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ0REI0QzFEOUQyQjIyMEQKUldRTklpdWRIVXpiMU9qTUhLRFBycXhveHV5VWhka1dZbFBVZ3huMnhDdW43NWF4aStyVTBRYisK",
      "endpoints": [
        "https://github.com/ComputelessComputer/unsigned-char/releases/latest/download/latest.json"
      ]
    }
  }
}
