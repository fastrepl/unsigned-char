#!/bin/sh

set -eu

resolve_script_dir() {
  script_path=$1

  while [ -L "$script_path" ]; do
    script_dir=$(cd -P "$(dirname "$script_path")" && pwd)
    link_target=$(readlink "$script_path")
    case "$link_target" in
      /*) script_path=$link_target ;;
      *) script_path="$script_dir/$link_target" ;;
    esac
  done

  cd -P "$(dirname "$script_path")" && pwd
}

fail() {
  printf "uchar: %s\n" "$1" >&2
  exit 1
}

script_dir=$(resolve_script_dir "$0")
contents_dir=$(cd "$script_dir/.." && pwd)
info_plist="$contents_dir/Info.plist"
main_executable=$(
  /usr/libexec/PlistBuddy -c "Print :CFBundleExecutable" "$info_plist" 2>/dev/null ||
    printf "unsigned-char"
)
main_binary="$script_dir/$main_executable"

if [ ! -x "$main_binary" ]; then
  fail "could not find the bundled unsigned Char executable."
fi

exec "$main_binary" --uchar-cli "$@"
